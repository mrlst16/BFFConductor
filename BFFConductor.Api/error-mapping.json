{
  "defaults": {
    "displayMode": "toast"
  },
  "mappings": [
    { "errorCode": "1001", "httpStatus": 422, "displayMode": "inline" },
    { "errorCode": "1002", "httpStatus": 404, "displayMode": "toast" },
    { "errorCode": "1003", "httpStatus": 401, "displayMode": "snackbar" },
    {
      "errorCode": "1004",
      "httpStatus": 403,
      "displayMode": "redirect",
      "additionalHeaders": {
        "x-redirect-url": "/error",
        "x-redirect-message": "You do not have permission to access this resource."
      }
    },
    { "errorCode": "0", "httpStatus": 500, "displayMode": "silent" }
  ],
  "exceptionMappings": [
    { "exceptionType": "ArgumentNullException", "httpStatus": 422, "displayMode": "inline", "errorCode": "1001" },
    { "exceptionType": "ArgumentException", "httpStatus": 400, "displayMode": "toast", "errorCode": "1001" },
    { "exceptionType": "InvalidOperationException", "httpStatus": 500, "displayMode": "toast", "errorCode": "0" }
  ]
}
